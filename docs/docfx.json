{
  "metadata": [
    {
      "src": [
        {
          "src": "../src",
          "files": [
            "**/*.csproj"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "index.md",
          "toc.yml",
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**",
          "node_modules/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "robots.txt"
        ],
        "exclude": [
          "_site/**",
          "node_modules/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern",
      "templates/visus"
    ],
    "sitemap": {
      "baseUrl": "https://ave.projects.visus.io",
      "changefreq": "monthly"
    },
    "globalMetadata": {
      "_appName": "AddressValidation",
      "_appTitle": "AddressValidation",
      "_appFooter": "<span>Copyright &copy; 2024-2026 Visus Development Team. Built with <a href=\"https://docfx.github.io/docfx\">docfx</a>.</span>",
      "_enableSearch": true,
      "_lang": "en",
      "pdf": false
    }
  }
}
