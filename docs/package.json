{
  "name": "addressvalidation-docs-watch",
  "description": "Address Validation Library Documentation Watcher",
  "scripts": {
    "watch": "chokidar 'api/**/*.{md,yml}' 'docs/**/*.{md,yml}' 'toc.yml' 'index.md' -c 'bun run build'",
    "build": "docfx build --serve"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/visus-io/addressvalidation.git"
  },
  "author": "Visus Development Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/visus-io/addressvalidation/issues"
  },
  "homepage": "https://github.com/visus-io/addressvalidation#readme",
  "devDependencies": {
    "chokidar-cli": "^3.0.0"
  }
}
